{
  "name": "sibot",
  "productName": "SIBOT",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "SIBOT - real-time taunt assistant for game streamers",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "package:dir": "electron-vite build && electron-builder --dir",
    "package:win": "electron-vite build && electron-builder --win nsis"
  },
  "dependencies": {
    "active-win": "^8.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "systeminformation": "^5.25.11",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.0.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1"
  },
  "build": {
    "appId": "com.sibot.desktop",
    "productName": "SIBOT",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "README.md"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "SIBOT-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
